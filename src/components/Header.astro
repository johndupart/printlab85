---
// src/components/Header.astro
---

<header class="fixed top-6 left-0 w-full z-[100] flex justify-center ">
    <nav class="flex items-center border mx-4 max-md:w-full max-md:justify-between border-slate-700/50 px-6 py-2 rounded-full text-white bg-brand-dark/40 backdrop-blur-xl transition-all duration-300 shadow-lg shadow-black/20 relative">
        
        <a href="/" class="flex items-center">
            <img 
                src="/logo.svg" 
                alt="Printlab 85 Logo" 
                class="h-14 w-auto object-contain hover:scale-105 transition-transform duration-300"
            />
        </a>

        <div class="hidden md:flex items-center gap-7 ml-8">
            {['Servicios', 'Como Funciona', 'Ropa', 'Taller', 'Contacto'].map((item) => (
                <a href={`#${item.toLowerCase().replace(/\s+/g, '-')}`} class="relative block overflow-hidden group h-[20px]">
                    <div class="transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:-translate-y-1/2">
                        <span class="flex items-center justify-center h-[20px] uppercase tracking-wider font-medium text-[12px] whitespace-nowrap">
                            {item}
                        </span>
                        <span class="flex items-center justify-center h-[20px] uppercase tracking-wider font-bold text-[12px] text-brand-blue whitespace-nowrap">
                            {item}
                        </span>
                    </div>
                </a>
            ))}
        </div>

        <div class="hidden ml-14 md:flex items-center gap-4">
            <button class="bg-white text-black px-5 py-2 rounded-full text-[12px] font-bold uppercase hover:bg-brand-blue hover:text-white hover:shadow-[0px_0px_25px_rgba(30,112,182,0.6)] transition-all duration-500">
                Cotizar ahora
            </button>
        </div>

        <button id="menuToggle" class="md:hidden flex flex-col justify-center items-center gap-1.5 w-10 h-10 focus:outline-none group relative z-[110]">
            <span id="line1" class="w-6 h-0.5 bg-white transition-all duration-300 origin-center"></span>
            <span id="line2" class="w-6 h-0.5 bg-white transition-all duration-300"></span>
            <span id="line3" class="w-6 h-0.5 bg-white transition-all duration-300 origin-center"></span>
        </button>

        <div id="mobileMenu" class="fixed invisible opacity-0 translate-y-4 top-20 left-0 right-0 mx-auto w-[95%] bg-[#0a0a0a]/fb border border-slate-700/20 rounded-[2.5rem] p-10 flex flex-col items-center gap-8 text-center backdrop-blur-[40px] transition-all duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] shadow-[0_20px_50px_rgba(0,0,0,0.5)] z-[105]">
            <div class="flex flex-col gap-6 w-full">
                <a class="mobile-link text-xl font-black uppercase tracking-tighter text-white hover:text-brand-blue transition-colors" href="#servicios">Servicios</a>
                <a class="mobile-link text-xl font-black uppercase tracking-tighter text-white hover:text-brand-blue transition-colors" href="#como-funciona">Como Funciona</a>
                <a class="mobile-link text-xl font-black uppercase tracking-tighter text-white hover:text-brand-blue transition-colors" href="#ropa">Ropa</a>
                <a class="mobile-link text-xl font-black uppercase tracking-tighter text-white hover:text-brand-blue transition-colors" href="#taller">Taller</a>
                <a class="mobile-link text-xl font-black uppercase tracking-tighter text-white hover:text-brand-blue transition-colors" href="#contacto">Contacto</a>
            </div>
            
            <div class="w-full h-[1px] bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
            
            <button class="w-full py-5 bg-brand-blue text-white rounded-2xl text-xl font-black uppercase tracking-widest shadow-[0_10px_30px_rgba(30,112,182,0.4)] active:scale-95 transition-transform">
                Cotizar Ahora
            </button>
        </div>
    </nav>
</header>

<script>
    const menuToggle = document.getElementById('menuToggle');
    const mobileMenu = document.getElementById('mobileMenu');
    const line1 = document.getElementById('line1');
    const line2 = document.getElementById('line2');
    const line3 = document.getElementById('line3');
    const body = document.body;
    const mobileLinks = document.querySelectorAll('.mobile-link');

    const toggleMenu = () => {
        const isOpen = mobileMenu?.classList.contains('visible');
        
        if (!isOpen) {
            // Abrir
            mobileMenu?.classList.remove('invisible', 'opacity-0', 'translate-y-4');
            mobileMenu?.classList.add('visible', 'opacity-100', 'translate-y-0');
            
            // Animación X
            line1?.classList.add('rotate-45', 'translate-y-[8px]');
            line2?.classList.add('opacity-0', 'scale-0');
            line3?.classList.add('-rotate-45', '-translate-y-[8px]');
            
            // Bloquear Scroll
            body.style.overflow = 'hidden';
        } else {
            // Cerrar
            mobileMenu?.classList.add('invisible', 'opacity-0', 'translate-y-4');
            mobileMenu?.classList.remove('visible', 'opacity-100', 'translate-y-0');
            
            // Revertir Icono
            line1?.classList.remove('rotate-45', 'translate-y-[8px]');
            line2?.classList.remove('opacity-0', 'scale-0');
            line3?.classList.remove('-rotate-45', '-translate-y-[8px]');
            
            // Habilitar Scroll
            body.style.overflow = '';
        }
    };

    menuToggle?.addEventListener('click', toggleMenu);

    // Cerrar menú al hacer clic en un enlace y permitir el scroll
    mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
            if (mobileMenu?.classList.contains('visible')) {
                toggleMenu();
            }
        });
    });
</script>

<style>
    /* Soporte para navegadores que no manejan bien el backdrop-blur */
    #mobileMenu {
        background-color: rgba(10, 10, 10, 0.98);
    }
    
    /* Evita que el tap de móvil resalte en azul feo */
    #menuToggle, .mobile-link {
        -webkit-tap-highlight-color: transparent;
    }
</style>