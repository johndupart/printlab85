---
const brands = [
  { name: "PIZZAQUIRA", src: "/images/logos/pizzaquira.png" },
  { name: "ape", src: "/images/logos/ape.png" },
  { name: "chivato", src: "/images/logos/chivato.png" },
  { name: "eltopping", src: "/images/logos/eltopping.png" },
  { name: "Conecta", src: "/images/logos/conecta.png" },
  { name: "vita", src: "/images/logos/vita.png" },
  { name: "zipaquiradigital", src: "/images/logos/zipaquiradigital.png" }
];
---

<section class="w-full bg-background-dark py-12 md:py-20 border-y border-white/10">
  <div class="max-w-7xl mx-auto px-6 flex flex-col lg:flex-row items-start lg:items-center gap-8 lg:gap-16">
    
   <div class="w-full lg:w-52 shrink-0 relative z-20 flex flex-col items-center text-center">
      <p class="text-[10px] uppercase tracking-[0.5em] text-primary font-black leading-tight">
        Marcas que <br class="hidden lg:block"/> confían en <br class="hidden lg:block"/> nosotros
      </p>
      <div class="h-px w-10 bg-primary/40 mt-4"></div>
    </div>

    <div class="relative w-full flex-1 overflow-hidden py-4">
      
      <div class="absolute inset-y-0 left-0 w-12 md:w-24 bg-gradient-to-r from-background-dark via-background-dark/60 to-transparent z-10 pointer-events-none"></div>
      <div class="absolute inset-y-0 right-0 w-12 md:w-24 bg-gradient-to-l from-background-dark via-background-dark/60 to-transparent z-10 pointer-events-none"></div>

      <div class="flex overflow-hidden group">
        <div class="flex animate-marquee-pro whitespace-nowrap gap-12 md:gap-24 items-center">
          {[...brands, ...brands].map((brand) => (
            <div class="flex items-center gap-6 md:gap-20 group/item">
             <img 
  src={brand.src} 
  alt={brand.name} 
  class="h-12 md:h-16 w-auto max-w-[140px] md:max-w-[180px] object-contain opacity-80  hover:opacity-100 hover:grayscale-0 transition-all duration-500 hover:scale-105 select-none"
/>
              <span class="text-primary/30 font-light text-2xl md:text-3xl">/</span>
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* Velocidad equilibrada */
  .animate-marquee-pro {
    animation: marquee-ultra 112s linear infinite;
    display: flex;
    width: max-content;
  }

  @keyframes marquee-ultra {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .group:hover .animate-marquee-pro {
    animation-play-state: paused;
  }

  .animate-marquee-pro {
    will-change: transform;
    backface-visibility: hidden;
  }

  @media (max-width: 640px) {
    .animate-marquee-pro {
      animation-duration: 70s;
    }
  }
</style>