---
// src/components/Contact.astro
---

<section id="contacto" class="relative z-20 py-24 md:py-32 px-4 bg-background-dark overflow-hidden border-t border-white/5">
  
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vw] h-[80vw] md:w-[40vw] md:h-[40vw] bg-primary/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="w-full max-w-7xl mx-auto flex flex-col lg:flex-row gap-16 lg:gap-24 items-center">
    
    <div class="w-full lg:w-1/2 flex flex-col justify-center relative z-10">
      
      <div class="contact-header mb-12">
        <h2 class="text-brand-blue font-bold tracking-[0.2em] text-sm uppercase mb-6 opacity-0 translate-y-4">Inicia tu proyecto</h2>
        <p class="text-5xl md:text-7xl lg:text-[6rem] font-black text-white uppercase tracking-tighter leading-[0.85] opacity-0 translate-y-8">
          Hablemos.
        </p>
      </div>

      <div class="flex flex-col gap-10">
        
        <div class="contact-item opacity-0 translate-y-8 flex gap-6 items-start group">
          <div class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center bg-white/5 group-hover:bg-primary/20 group-hover:border-primary/50 group-hover:text-primary transition-all duration-500 shrink-0 text-white/50">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <h4 class="text-white text-xs font-bold uppercase tracking-widest mb-2">Visítanos</h4>
            <p class="text-slate-400 text-base md:text-lg font-light leading-relaxed max-w-sm group-hover:text-white transition-colors duration-300">
              Cr 17 # 18-42<br/>
              Barrio San Rafael "5 esquinas"<br/>
              Zipaquirá, Cundinamarca
            </p>
          </div>
        </div>

        <div class="contact-item opacity-0 translate-y-8 flex gap-6 items-start group">
          <div class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center bg-white/5 group-hover:bg-primary/20 group-hover:border-primary/50 group-hover:text-primary transition-all duration-500 shrink-0 text-white/50">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <h4 class="text-white text-xs font-bold uppercase tracking-widest mb-2">Llámanos</h4>
            <a href="tel:+573241443221" class="text-slate-400 text-xl md:text-2xl font-light leading-relaxed hover:text-white transition-colors duration-300 inline-block">
              324 144 3221
            </a>
          </div>
        </div>

        <div class="contact-item opacity-0 translate-y-8 mt-4">
          <a href="https://wa.me/573241443221" target="_blank" rel="noopener noreferrer" class="magnetic-btn relative inline-flex items-center justify-center px-8 py-4 bg-white/5 border border-white/10 rounded-full overflow-hidden group hover:border-primary/50 transition-colors duration-300">
            <div class="absolute inset-0 bg-primary translate-y-[100%] rounded-full group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]"></div>
            
            <span class="relative z-10 flex items-center gap-3 text-white font-bold uppercase tracking-widest text-xs">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="text-white">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
              </svg>
              Contactar por WhatsApp
            </span>
          </a>
        </div>

      </div>
    </div>

    <div class="w-full lg:w-1/2 map-container opacity-0 translate-y-12">
      <div class="relative w-full aspect-square md:aspect-[4/3] lg:aspect-square overflow-hidden rounded-[40px] shadow-[0_0_40px_rgba(0,0,0,0.5)] border border-white/10 group bg-white/5">
        
        <div class="absolute inset-0 z-10 pointer-events-none group-hover:pointer-events-auto"></div>

        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15893.633454792683!2d-74.01334674999999!3d5.037130200000001!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e40702d7ebff84f%3A0xcda6b23a2a62887a!2sZipaquir%C3%A1%2C%20Cundinamarca!5e0!3m2!1ses!2sco!4v1700000000000!5m2!1ses!2sco" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          class="w-full h-full grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 ease-in-out scale-105 group-hover:scale-100"
        ></iframe>
        
        <div class="absolute inset-0 pointer-events-none shadow-[inset_0_0_50px_rgba(16,30,34,0.8)] z-20 rounded-[40px]"></div>
      </div>
    </div>

  </div>
</section>

<script>
  import { animate, inView, stagger } from "motion";

  // 1. Animaciones de entrada al hacer scroll
  const section = document.getElementById("contacto");
  
  if (section) {
    inView(section, () => {
      // Convertimos los NodeList a Arrays y forzamos el tipado con 'as any'
      const headers = Array.from(document.querySelectorAll(".contact-header > *")) as any;
      animate(
        headers, 
        { opacity: [0, 1], y: [20, 0] } as any, 
        { duration: 0.8, delay: stagger(0.1), easing: [0.22, 1, 0.36, 1] } as any
      );

      // Animar items de contacto (Dirección, Teléfono, Botón)
      const items = Array.from(document.querySelectorAll(".contact-item")) as any;
      animate(
        items, 
        { opacity: [0, 1], y: [30, 0] } as any, 
        // ¡SOLUCIÓN AQUÍ! Agregamos 'as any' al objeto { start: 0.3 }
        { duration: 0.8, delay: stagger(0.15, { start: 0.3 } as any), easing: [0.22, 1, 0.36, 1] } as any
      );

      // Animar contenedor del mapa
      const mapContainer = document.querySelector(".map-container") as any;
      if (mapContainer) {
        animate(
          mapContainer, 
          { opacity: [0, 1], y: [40, 0] } as any, 
          { duration: 1, delay: 0.5, easing: [0.22, 1, 0.36, 1] } as any
        );
      }
    });
  }

  // 2. Lógica del Botón Magnético
  const magneticBtns = document.querySelectorAll('.magnetic-btn');

  magneticBtns.forEach((btn) => {
    const htmlBtn = btn as HTMLElement;
    const textElement = htmlBtn.querySelector('span') as HTMLElement;
    
    htmlBtn.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = htmlBtn.getBoundingClientRect();
      const h = rect.width / 2;
      const v = rect.height / 2;
      
      const x = e.clientX - rect.left - h;
      const y = e.clientY - rect.top - v;
      
      htmlBtn.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
      if(textElement) textElement.style.transform = `translate(${x * 0.1}px, ${y * 0.1}px)`;
    });

    htmlBtn.addEventListener('mouseleave', () => {
      htmlBtn.style.transform = 'translate(0px, 0px)';
      if(textElement) textElement.style.transform = 'translate(0px, 0px)';
    });
  });
</script>

<style>
  /* Transición de resorte para el botón magnético cuando se suelta */
  .magnetic-btn, .magnetic-btn span {
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  
  .magnetic-btn:hover, .magnetic-btn:hover span {
    transition: transform 0.1s linear; /* Más rápido mientras sigue al mouse */
  }
</style>