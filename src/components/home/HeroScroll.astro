---
const sections = [
  {
    left: "Identidad",
    title: "SERIGRAFÍA",
    right: "Artesanal",
    bg: "/images/serigrafia.webp",
    bgMobile: "/images/serigrafia_movil.webp", // Tu versión 9:16
  },
  {
    left: "Calidad",
    title: "BOLSAS KRAFT",
    right: "Ecológico",
    bg: "/images/bolsa_kraft.webp",
    bgMobile: "/images/bolsa_kraft_movil.webp", // Tu versión 9:16
  },
  {
    left: "Estilo",
    title: "ROPA CASUAL",
    right: "Premium",
    bg: "/images/tienda.webp",
    bgMobile: "/images/tienda_movil.webp", // Tu versión 9:16
  },
];

const transparentPixel =
  "data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=";
---

<section id="hero-container" class="relative bg-background-dark">
  <h1 class="sr-only">
    Printlab.85: serigrafía, estampado DTF, ropa y bolsas kraft en Zipaquirá
  </h1>
  <div class="sticky top-0 h-screen w-full overflow-hidden">
    
    <div class="absolute inset-0 z-0">
      {sections.map((s, i) => (
        <div 
          data-bg-index={i} 
          class={`absolute inset-0 transition-opacity duration-1000 ease-in-out ${
            i === 0 ? "opacity-100" : "opacity-0"
          }`}
        >
          <picture class="block h-full w-full">
            <source
              media="(max-width: 767px)"
              srcset={i === 0 ? s.bgMobile : undefined}
              data-srcset={i === 0 ? undefined : s.bgMobile}
              width="900"
              height="1600"
            />
            <img
              src={i === 0 ? s.bg : transparentPixel}
              data-src={i === 0 ? undefined : s.bg}
              alt=""
              width="1920"
              height="1080"
              loading={i === 0 ? "eager" : "lazy"}
              decoding="async"
              fetchpriority={i === 0 ? "high" : "low"}
              class="h-full w-full object-cover brightness-[0.3]"
            />
          </picture>

          <div class="absolute inset-0 bg-gradient-to-b from-background-dark/30 via-transparent to-background-dark"></div>
        </div>
      ))}
    </div>

    <div class="relative z-10 h-full w-full grid grid-cols-12 grid-rows-6 px-8 py-12 text-white">
      
      <div class="col-span-12 row-start-1 self-start text-center">
        <p class="text-xs font-bold tracking-[0.4em] opacity-40 uppercase">Printlab Studio / Process</p>
      </div>

      <div class="col-span-12 row-start-3 row-end-5 flex items-center justify-between pointer-events-none">
        
        <div class="w-1/4 hidden md:block">
            <div id="left-labels" class="flex flex-col gap-6">
                {sections.map((s, i) => (
                    <span data-label-index={i} class="text-xs font-black uppercase tracking-[0.2em] opacity-10 transition-all duration-700 ease-out origin-left inline-block">
                        {s.left}
                    </span>
                ))}
            </div>
        </div>

        <div class="flex-1 text-center relative h-40 flex items-center justify-center">
            {sections.map((s, i) => (
                <p
                    data-title-index={i} 
                    class={`absolute text-[clamp(2.5rem,12vw,9rem)] font-black leading-none transition-all duration-1000 ease-out text-white tracking-tighter ${
                      i === 0
                        ? "opacity-100 translate-y-0"
                        : "opacity-0 translate-y-12"
                    }`}
                >
                    {s.title}
                </p>
            ))}
        </div>

        <div class="w-1/4 hidden md:block text-right">
            <div id="right-labels" class="flex flex-col gap-6">
                {sections.map((s, i) => (
                    <span data-label-index={i} class="text-xs font-black uppercase tracking-[0.2em] opacity-10 transition-all duration-700 ease-out origin-right inline-block">
                        {s.right}
                    </span>
                ))}
            </div>
        </div>
      </div>

      <div class="col-span-12 row-start-6 self-end flex flex-col items-center">
        <span class="text-[10px] font-bold tracking-[0.5em] mb-6 opacity-50 uppercase">Zipaquirá, Colombia</span>
        <div class="w-64 h-[1px] bg-white/10 relative overflow-hidden">
            <div id="progress-bar" class="absolute top-0 left-0 h-full bg-primary w-0 transition-all duration-200 shadow-[0_0_10px_#0db9f2]"></div>
        </div>
      </div>

    </div>
  </div>

  <div class="h-[400vh] w-full pointer-events-none"></div>
</section>

<script>
  import { scroll } from "motion";

  const container = document.querySelector("#hero-container") as HTMLElement;
  const bgs = document.querySelectorAll("[data-bg-index]");
  const titles = document.querySelectorAll("[data-title-index]");
  const allLabels = document.querySelectorAll("[data-label-index]");
  const progressBar = document.querySelector("#progress-bar") as HTMLElement;
  
  const totalSections = bgs.length;

  const loadBackground = (index: number) => {
    const background = bgs[index] as HTMLElement | undefined;
    if (!background) return;

    const source = background.querySelector(
      "source[data-srcset]"
    ) as HTMLSourceElement | null;

    const image = background.querySelector(
      "img[data-src]"
    ) as HTMLImageElement | null;

    const nextSource = source?.dataset.srcset;
    const nextImage = image?.dataset.src;

    if (source && nextSource) {
      source.srcset = nextSource;
      delete source.dataset.srcset;
    }

    if (image && nextImage) {
      image.src = nextImage;
      delete image.dataset.src;
    }
  };

  if (container) {
    scroll((progress: number) => {
      const activeIndex = Math.min(
          totalSections - 1,
          Math.floor(progress * totalSections)
      );

      const preloadIndex = Math.min(
          totalSections - 1,
          Math.floor((progress + 0.15) * totalSections)
      );

      loadBackground(activeIndex);
      loadBackground(preloadIndex);

      if (progressBar) {
          progressBar.style.width = `${progress * 100}%`;
      }

      bgs.forEach((bg, i) => {
          (bg as HTMLElement).style.opacity = i === activeIndex ? "1" : "0";
      });

      titles.forEach((title, i) => {
          const el = title as HTMLElement;
          if (i === activeIndex) {
              el.style.opacity = "1";
              el.style.transform = "translateY(0px)";
          } else {
              el.style.opacity = "0";
              el.style.transform = "translateY(40px)";
          }
      });

      allLabels.forEach((label) => {
          const el = label as HTMLElement;
          const labelIndex = parseInt(el.getAttribute('data-label-index') || "0");

          if (labelIndex === activeIndex) {
              el.style.opacity = "1";
              el.style.color = "#1e70b6"; 
              el.style.transform = "scale(1.3)"; 
              el.style.textShadow = "0 0 20px rgba(13, 185, 242, 0.8)";
              el.style.filter = "brightness(1.5)";
          } else {
              el.style.opacity = "0.1";
              el.style.color = "#ffffff";
              el.style.transform = "scale(1)";
              el.style.textShadow = "none";
              el.style.filter = "brightness(1)";
          }
      });

    }, {
      target: container,
      offset: ["start start", "end end"]
    });
  }
</script>

<style>
    [data-title-index], [data-label-index] {
        transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: transform, opacity, color, text-shadow, filter;
    }

    span[data-label-index] {
        backface-visibility: hidden;
        display: inline-block;
    }

    [data-bg-index] {
        will-change: opacity;
    }
</style>