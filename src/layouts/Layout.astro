---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import StickyCTA from '../components/StickyCTA.astro';
import '../styles/global.css';

type SchemaNode = Record<string, unknown>;

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  canonical?: string;
  keywords?: string[];
  noindex?: boolean;
  ogType?: 'website' | 'article';
  schemaNodes?: SchemaNode[];
}

const defaultKeywords = [
  'serigrafía en Zipaquirá',
  'estampados personalizados Zipaquirá',
  'estampado DTF',
  'impresión DTF Zipaquirá',
  'camisetas personalizadas',
  'vinilo textil',
  'bolsas kraft personalizadas',
  'empaques personalizados',
  'diseño gráfico Zipaquirá',
  'estampados en Cundinamarca',
  'Printlab 85'
];

const {
  title = 'Printlab85 | Serigrafía, DTF, Ropa y Estampados en Zipaquirá',
  description = 'Serigrafía, estampado DTF, vinilo textil, venta de ropa camisetas y bolsas kraft personalizadas en Zipaquirá y sababana centro. Soluciones para marcas, empresas y emprendimientos.',
  image = '/og-image.jpg',
  imageAlt = 'Printlab85, taller de serigrafía, estampados personalizados venta de ropa y accesorios en Zipaquirá',
  canonical,
  keywords = defaultKeywords,
  noindex = false,
  ogType = 'website',
  schemaNodes = []
} = Astro.props;

const siteURL =
  Astro.site ?? new URL('https://printlab85.com');

const homeURL = new URL('/', siteURL).href;

const canonicalURL = canonical
  ? new URL(canonical, siteURL).href
  : new URL(Astro.url.pathname, siteURL).href;

const imageURL = new URL(image, siteURL).href;
const logoURL = new URL('/logo.svg', siteURL).href;
const sitemapURL = new URL('/sitemap.xml', siteURL).href;
const businessId = `${homeURL}#business`;
const websiteId = `${homeURL}#website`;
const webpageId = `${canonicalURL}#webpage`;
const imageId = `${canonicalURL}#primaryimage`;

const robotsContent = noindex
  ? 'noindex, nofollow, noarchive'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ImageObject',
      '@id': imageId,
      url: imageURL,
      contentUrl: imageURL,
      caption: imageAlt,
      inLanguage: 'es-CO'
    },
    {
      '@type': 'LocalBusiness',
      '@id': businessId,
      name: 'Printlab.85',
      alternateName: [
        'Printlab 85',
        'Printlab Zipaquirá'
      ],
      description:
        'Taller creativo en Zipaquirá especializado en serigrafía, estampado DTF, vinilo textil, camisetas personalizadas, bolsas kraft y soluciones gráficas para marcas, empresas y emprendimientos.',
      url: homeURL,
      logo: logoURL,
      image: {
        '@id': imageId
      },
      telephone: '+573241443221',
      priceRange: '$$',
      currenciesAccepted: 'COP',
      address: {
        '@type': 'PostalAddress',
        streetAddress:
          'Carrera 17 #18-42, barrio San Rafael, sector Cinco Esquinas',
        addressLocality: 'Zipaquirá',
        addressRegion: 'Cundinamarca',
        postalCode: '250252',
        addressCountry: {
          '@type': 'Country',
          name: 'CO'
        }
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 5.0215,
        longitude: -74.0042
      },
      openingHoursSpecification: [
        {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: [
            'https://schema.org/Tuesday',
            'https://schema.org/Wednesday',
            'https://schema.org/Thursday'
          ],
          opens: '08:00',
          closes: '20:30'
        },
        {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: 'https://schema.org/Friday',
          opens: '08:00',
          closes: '21:00'
        },
        {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: 'https://schema.org/Saturday',
          opens: '08:00',
          closes: '15:00'
        }
      ],
      contactPoint: {
        '@type': 'ContactPoint',
        telephone: '+573241443221',
        contactType: 'customer service',
        areaServed: [
          'Zipaquirá',
          'Cajicá',
          'Chía',
          'Sabana Centro',
          'Bogotá',
          'Cundinamarca',
          'Colombia'
        ],
        availableLanguage: [
          'es',
          'es-CO'
        ]
      },
      areaServed: [
        {
          '@type': 'City',
          name: 'Zipaquirá'
        },
        {
          '@type': 'AdministrativeArea',
          name: 'Sabana Centro'
        },
        {
          '@type': 'AdministrativeArea',
          name: 'Cundinamarca'
        },
        {
          '@type': 'Country',
          name: 'Colombia'
        }
      ],
      sameAs: [
        'https://www.instagram.com/printlab.85/',
        'https://www.facebook.com/profile.php?id=61555849196274'
      ],
      knowsAbout: [
        'Serigrafía',
        'Estampado DTF',
        'Vinilo textil',
        'Diseño gráfico',
        'Camisetas personalizadas',
        'Bolsas kraft personalizadas',
        'Empaques personalizados'
      ],
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Servicios de estampado y diseño de Printlab.85',
        itemListElement: [
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Serigrafía profesional',
              description:
                'Impresión en serigrafía para prendas, marcas, empresas y producciones personalizadas.',
              provider: {
                '@id': businessId
              },
              areaServed: 'Colombia'
            }
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Estampado DTF',
              description:
                'Estampado DTF full color para prendas personalizadas desde una unidad.',
              provider: {
                '@id': businessId
              },
              areaServed: 'Colombia'
            }
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Vinilo textil',
              description:
                'Personalización de prendas, nombres, números y diseños mediante vinilo textil.',
              provider: {
                '@id': businessId
              },
              areaServed: 'Colombia'
            }
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Camisetas personalizadas',
              description:
                'Producción de camisetas y prendas personalizadas para empresas, marcas y eventos.',
              provider: {
                '@id': businessId
              },
              areaServed: 'Colombia'
            }
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Bolsas kraft personalizadas',
              description:
                'Diseño y estampado de bolsas kraft y empaques personalizados para negocios.',
              provider: {
                '@id': businessId
              },
              areaServed: 'Colombia'
            }
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Diseño gráfico',
              description:
                'Diseño, adaptación y vectorización de piezas gráficas para prendas y empaques.',
              provider: {
                '@id': businessId
              },
              areaServed: 'Colombia'
            }
          }
        ]
      }
    },
    {
      '@type': 'WebSite',
      '@id': websiteId,
      url: homeURL,
      name: 'Printlab.85',
      alternateName: 'Printlab 85',
      description,
      inLanguage: 'es-CO',
      publisher: {
        '@id': businessId
      }
    },
    {
      '@type': 'WebPage',
      '@id': webpageId,
      url: canonicalURL,
      name: title,
      description,
      inLanguage: 'es-CO',
      isPartOf: {
        '@id': websiteId
      },
      about: {
        '@id': businessId
      },
      primaryImageOfPage: {
        '@id': imageId
      },
      thumbnailUrl: imageURL,
      potentialAction: {
        '@type': 'ReadAction',
        target: [canonicalURL]
      }
    },
    ...schemaNodes
  ]
};
---

<!doctype html>
<html lang="es-CO">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.ico"
    />

    <meta
      name="generator"
      content={Astro.generator}
    />

    <meta
      name="theme-color"
      content="#101e22"
    />

    <meta
      name="color-scheme"
      content="dark"
    />

    <meta
      name="robots"
      content={robotsContent}
    />

    <meta
      name="googlebot"
      content={robotsContent}
    />

    <meta
      name="referrer"
      content="strict-origin-when-cross-origin"
    />

    <link
      rel="canonical"
      href={canonicalURL}
    />

    <link
      rel="alternate"
      hreflang="es-CO"
      href={canonicalURL}
    />

    <link
      rel="alternate"
      hreflang="x-default"
      href={canonicalURL}
    />

    <link
      rel="sitemap"
      href={sitemapURL}
    />

    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />

    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400..700&family=Manrope:wght@200..800&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />

    <title>{title}</title>

    <meta
      name="title"
      content={title}
    />

    <meta
      name="description"
      content={description}
    />

    <meta
      name="author"
      content="Printlab.85"
    />

    <meta
      name="keywords"
      content={keywords.join(', ')}
    />

    <meta
      name="geo.region"
      content="CO-CUN"
    />

    <meta
      name="geo.placename"
      content="Zipaquirá"
    />

    <meta
      name="geo.position"
      content="5.0215;-74.0042"
    />

    <meta
      name="ICBM"
      content="5.0215, -74.0042"
    />

    <meta
      property="og:type"
      content={ogType}
    />

    <meta
      property="og:url"
      content={canonicalURL}
    />

    <meta
      property="og:title"
      content={title}
    />

    <meta
      property="og:description"
      content={description}
    />

    <meta
      property="og:image"
      content={imageURL}
    />

    <meta
      property="og:image:secure_url"
      content={imageURL}
    />

    <meta
      property="og:image:alt"
      content={imageAlt}
    />

    <meta
      property="og:site_name"
      content="Printlab.85"
    />

    <meta
      property="og:locale"
      content="es_CO"
    />

    <meta
      name="twitter:card"
      content="summary_large_image"
    />

    <meta
      name="twitter:url"
      content={canonicalURL}
    />

    <meta
      name="twitter:title"
      content={title}
    />

    <meta
      name="twitter:description"
      content={description}
    />

    <meta
      name="twitter:image"
      content={imageURL}
    />

    <meta
      name="twitter:image:alt"
      content={imageAlt}
    />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(schema)}
    />

    <slot name="head" />
  </head>

  <body>
    <Header />
    <slot />
    <Footer />
    <StickyCTA />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100%;
    font-family: 'Manrope', system-ui, sans-serif;
  }
</style>