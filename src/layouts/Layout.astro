---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { 
    title = "Printlab.85 | Estampados, Serigrafía y Diseño en Zipaquirá", 
    description = "Taller creativo en Zipaquirá especializado en serigrafía, Estampadas DTF, Bolsas kraft estampadas, Ropa casual y soluciones Gráficas personalizadas para marcas y empresas.",
    image = "/og-image.jpg"
} = Astro.props;

const canonicalURL = Astro.url.href;

// Datos Enriquecidos (JSON-LD) Avanzados para SEO, GEO y AEO
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://printlab85.com/#business",
      "name": "Printlab.85",
      "alternateName": "Printlab 85",
      "description": "Taller creativo y agencia de diseño especializada en serigrafía, estampados personalizados (DTF, vinilo textil), bolsas kraft y soluciones gráficas en Zipaquirá, Cundinamarca.",
      "url": "https://printlab85.com", // Cambiar por tu dominio final
      "logo": "https://printlab85.com/logo.svg", // Cambiar por la URL real de tu logo
      "image": new URL(image, Astro.url).href,
      "telephone": "+573241443221",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Cr 17 # 18-42 Barrio San Rafael ¨5 esquinas¨",
        "addressLocality": "Zipaquirá",
        "addressRegion": "Cundinamarca",
        "postalCode": "250252",
        "addressCountry": "CO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 5.0215,
        "longitude": -74.0042
      },
      "hasMap": "https://maps.app.goo.gl/tu-enlace-de-google-maps", // Cambia esto por tu enlace corto de Google Maps
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Monday", "opens": "00:00", "closes": "00:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "08:00", "closes": "20:30" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Wednesday", "opens": "08:00", "closes": "20:30" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Thursday", "opens": "08:00", "closes": "20:30" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Friday", "opens": "08:00", "closes": "21:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "15:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+573241443221",
        "contactType": "Customer Service",
        "areaServed": ["Zipaquirá", "Cajicá", "Chía", "Bogotá", "Cundinamarca", "Colombia"],
        "availableLanguage": "es"
      },
      "sameAs": [
        "https://www.instagram.com/printlab.85/", // Coloca aquí tus redes reales
        "https://www.facebook.com/profile.php?id=61555849196274"
      ],
      // AEO: Le dice a las IAs exactamente qué servicios ofreces
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios de Serigrafía y Diseño",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Serigrafía Profesional" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Estampado DTF" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Vinilo Textil" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Bolsas Kraft Personalizadas" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Diseño Gráfico" } }
        ]
      }
    }
  ]
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#101e22" /> <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />
    </noscript>

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Printlab.85" />
    
    <meta name="keywords" content="serigrafía zipaquira, estampados personalizados, impresión DTF, bolsas kraft personalizadas, diseño gráfico zipaquira, camisetas personalizadas, vinilo textil, taller de estampados cundinamarca, printlab 85, ropa premium estampada" />
    
    <link rel="canonical" href={canonicalURL} />

    <meta name="geo.region" content="CO-CUN" />
    <meta name="geo.placename" content="Zipaquirá" />
    <meta name="geo.position" content="5.0215;-74.0042" />
    <meta name="ICBM" content="5.0215, -74.0042" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:site_name" content="Printlab.85" />
    <meta property="og:locale" content="es_CO" /> <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    font-family: 'Inter', system-ui, sans-serif;
  }
</style>