---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const { 
    title = "Printlab.85 | Estampados, Serigrafía y Diseño en Zipaquirá", 
    description = "Taller creativo en Zipaquirá especializado en serigrafía, bolsas kraft estampadas, ropa de algodón y soluciones gráficas personalizadas para marcas.",
    image = "/og-image.jpg"
} = Astro.props;

const canonicalURL = Astro.url.href;

// Datos Enriquecidos basados en tu ficha de Google
const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Printlab.85",
  "alternateName": "Printlab 85",
  "description": "Taller creativo especializado en serigrafía, estampados personalizados y soluciones gráficas en Zipaquirá.",
  "url": "https://printlab85.com", // Cambiar cuando tengas el dominio final
  "telephone": "+573241443221",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Cr 17 # 18-42 Barrio San Rafael ¨5 esquinas¨",
    "addressLocality": "Zipaquirá",
    "addressRegion": "Cundinamarca",
    "postalCode": "250252",
    "addressCountry": "CO"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 5.0215, // Coordenadas aproximadas del barrio San Rafael
    "longitude": -74.0042
  },
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Monday", "opens": "00:00", "closes": "00:00" }, // Cerrado
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "02:00", "closes": "20:30" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Wednesday", "opens": "00:00", "closes": "20:30" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Thursday", "opens": "00:00", "closes": "20:30" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Friday", "opens": "00:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "00:00", "closes": "09:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "02:00", "closes": "07:00" }
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+573241443221",
    "contactType": "sales",
    "areaServed": "Zipaquirá"
  }
};
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
        <meta name="author" content="John Dupart" />
        <meta name="keywords" content="serigrafía zipaquira, estampados personalizados, bolsas kraft, diseño gráfico zipaquira, camisetas personalizadas, printlab 85" />
        <link rel="canonical" href={canonicalURL} />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
        <meta name="geo.region" content="CO-CUN" />
        <meta name="geo.placename" content="Zipaquirá" />
        <meta name="geo.position" content="5.0215;-74.0042" />
        <meta name="ICBM" content="5.0215, -74.0042" />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

        <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
	</head>
	<body>
		<Header />
		<slot />
		<Footer />
	</body>
</html>

<style is:global>
	html, body {
		margin: 0;
		padding: 0;
		width: 100%;
		height: 100%;
        font-family: 'Inter', system-ui, sans-serif;
	}
</style>