---
import AboutSection from '../components/home/AboutSection.astro';
import BrandMarquee from '../components/home/BrandMarquee.astro';
import Contact from '../components/home/Contact.astro';
import CtaMarquee from '../components/home/CtaMarquee.astro';
import FaqAccordion from '../components/home/FaqAccordion.astro';
import Features from '../components/home/Features.astro';
import HeroScroll from '../components/home/HeroScroll.astro';
import ProcessTimeline from '../components/home/ProcessTimeline.astro';
import ServicesGrid from '../components/home/ServicesGrid.astro';
import ServiceTable from '../components/home/ServiceTable.astro';
import Testimonial from '../components/home/Testimonial.astro';
import ZoomParallax from '../components/home/ZoomParallax.astro';
import Layout from '../layouts/Layout.astro';

// Optimización SEO, GEO y AEO específica para la portada (Home)
// Estos datos sobreescriben los props por defecto del Layout
const pageTitle = "Printlab.85 | Taller de Serigrafía y Estampados en Zipaquirá";
const pageDescription = "En Printlab.85 transformamos tus ideas en ropa premium y empaques ecológicos. Taller creativo en Zipaquirá especializado en serigrafía, DTF, vinilo textil y bolsas kraft.";

// Datos Enriquecidos Específicos de la Página (WebSite y WebPage)
// Esto crea una "telaraña semántica" uniendo esta página con tu negocio local
const homeSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://printlab85.com/#website",
      "url": "https://printlab85.com",
      "name": "Printlab.85",
      "description": pageDescription,
      "publisher": {
        "@id": "https://printlab85.com/#business" // Conecta con el schema del Layout
      },
      "inLanguage": "es-CO"
    },
    {
      "@type": "WebPage",
      "@id": "https://printlab85.com/#webpage",
      "url": "https://printlab85.com",
      "name": pageTitle,
      "isPartOf": {
        "@id": "https://printlab85.com/#website"
      },
      "about": {
        "@id": "https://printlab85.com/#business"
      },
      "description": pageDescription,
      "inLanguage": "es-CO"
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
    
    <script type="application/ld+json" is:inline set:html={JSON.stringify(homeSchema)} />

    <HeroScroll />
    <BrandMarquee />
    <AboutSection />
    <ServicesGrid />
    <ServiceTable />
    <ProcessTimeline />
    <ZoomParallax />
    <Testimonial />
    <FaqAccordion />
    <Contact />
    <CtaMarquee />
    
</Layout>